OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# Local dev (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./nutrimind.db

# Production (Supabase PostgreSQL) — replace with your connection string
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Supabase REST (required on Vercel for meal save/history/dashboard/report)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
